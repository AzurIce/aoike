{
	"devDependencies": {
		"@unocss/cli": "^0.53.3",
		"concurrently": "^8.2.0"
	},
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"uno": "unocss src/**/*.rs index.html --out-file static/uno.css",
		"dev": "concurrently \"trunk serve\" \"unocss src/**/*.rs index.html --out-file static/uno.css --watch\"",
		"build": "concurrently \"trunk build --release\" \"pnpm uno\""
	}
}
